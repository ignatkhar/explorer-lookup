{
  "name": "@bloxberg-org/explorer-lookup",
  "version": "1.2.1",
  "description": "A low level blockchain explorers lookup",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "import": "./lib/esm/index.js",
    "require": "./lib/cjs/index.js"
  },
  "types": "./lib/index.d.ts",
  "dependencies": {
    "ethereum-input-data-decoder": "^0.4.2",
    "xmlhttprequest": "^1.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "codecov": "^3.8.3",
    "dts-bundle-generator": "^9.5.1",
    "eslint": "^9.32.0",
    "husky": "^9.1.7",
    "rimraf": "^6.0.1",
    "semantic-release": "^24.2.3",
    "tslib": "^2.8.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.46.0",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "codecov": {
      "js-yaml": "3.14.2"
    }
  },
  "scripts": {
    "compile": "npm run clean:build && tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && npm run dts:bundle",
    "dts:bundle": "dts-bundle-generator -o ./lib/index.d.ts --project tsconfig.json --no-banner src/index.ts",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --silent --coverage.enabled",
    "test:coverage:report": "codecov",
    "semantic-release": "semantic-release",
    "clean:build": "rimraf lib",
    "prepublishOnly": "npm run compile",
    "prepare": "node -e \"if (!process.env.CI) require('child_process').execSync('husky install', { stdio: 'inherit' })\"",
    "build": "tsc -p tsconfig.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bloxberg-org/explorer-lookup.git"
  },
  "author": "Adi Ghag",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bloxberg-org/explorer-lookup/issues"
  },
  "homepage": "https://github.com/bloxberg-org/explorer-lookup#readme"
}
